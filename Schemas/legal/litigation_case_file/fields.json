  "fields": [
    {
      "name": "matter_id",
      "type": "string",
      "required": false,
      "description": "Internal matter or case file identifier.",
      "section": "document_details",
      "category": "descriptive"
    },
    {
      "name": "case_name",
      "type": "string",
      "required": true,
      "description": "Case caption or matter name.",
      "section": "parties",
      "category": "identity"
    },
    {
      "name": "court_name",
      "type": "string",
      "required": false,
      "description": "Court, arbitration forum, or tribunal.",
      "section": "parties",
      "category": "identity"
    },
    {
      "name": "case_number",
      "type": "string",
      "required": false,
      "description": "Court docket or arbitration number.",
      "section": "document_details",
      "category": "descriptive"
    },
    {
      "name": "case_type",
      "type": "string",
      "required": false,
      "description": "Commercial, employment, collections, bankruptcy, class action, arbitration, or other.",
      "section": "document_details",
      "category": "descriptive"
    },
    {
      "name": "plaintiff_names",
      "type": "array<string>",
      "required": false,
      "description": "Plaintiffs, claimants, or petitioners.",
      "section": "parties",
      "category": "array"
    },
    {
      "name": "defendant_names",
      "type": "array<string>",
      "required": false,
      "description": "Defendants, respondents, or opposing parties.",
      "section": "parties",
      "category": "array"
    },
    {
      "name": "client_role",
      "type": "string",
      "required": false,
      "description": "Plaintiff, defendant, third party, creditor, debtor, witness, or other.",
      "section": "risk_and_compliance",
      "category": "regulatory"
    },
    {
      "name": "lead_counsel_name",
      "type": "string",
      "required": false,
      "description": "Lead internal or external counsel.",
      "section": "parties",
      "category": "identity"
    },
    {
      "name": "law_firm",
      "type": "string",
      "required": false,
