      "section": "dates_and_terms",
      "category": "array"
    },
    {
      "name": "settlement_status",
      "type": "string",
      "required": false,
      "description": "Settlement posture or demand status.",
      "section": "risk_and_compliance",
      "category": "operational"
    },
    {
      "name": "exposure_amount",
      "type": "number",
      "required": false,
      "description": "Claimed damages, reserve, or exposure amount.",
      "section": "financials",
      "category": "financial"
    },
    {
      "name": "case_status",
      "type": "string",
      "required": true,
      "description": "Open, stayed, settled, judgment, closed, appealed, or other.",
      "section": "risk_and_compliance",
      "category": "operational"
    }
  ],
  "sections": [
    {
      "id": "dates_and_terms",
      "title": "Dates And Terms",
      "description": "Dates And Terms fields extracted from the document.",
      "fields": [
        "filing_date",
        "hearing_dates",
        "next_deadline_date",
        "next_deadline_description"
      ]
    },
    {
      "id": "document_details",
      "title": "Document Details",
      "description": "Document Details fields extracted from the document.",
      "fields": [
        "case_number",
        "case_type",
        "claims_or_causes",
        "key_motions",
        "law_firm",
        "matter_id"
      ]
    },
    {
      "id": "financials",
      "title": "Financials",
      "description": "Financials fields extracted from the document.",
      "fields": [
        "exposure_amount"
      ]
    },
    {
      "id": "parties",
      "title": "Parties",
      "description": "Parties fields extracted from the document.",
      "fields": [
        "case_name",
        "court_name",
        "defendant_names",
        "lead_counsel_name",
        "plaintiff_names"
      ]
    },
    {
      "id": "risk_and_compliance",
      "title": "Risk And Compliance",
      "description": "Risk And Compliance fields extracted from the document.",
      "fields": [
        "case_status",
        "client_role",
        "discovery_status",
        "settlement_status"
      ]
    }
