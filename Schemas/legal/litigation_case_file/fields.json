{
  "document_type": "litigation_case_file",
  "vertical": "legal",
  "family": "litigation_disputes",
  "schema_version": "legal_litigation_case_file_v1",
  "source_prompt": "prompt_v1.txt",
  "output_contract": {
    "fields_object": "extracted_fields",
    "confidence_object": "confidence",
    "metadata_object": "extraction_metadata"
