    {
      "name": "claims_or_causes",
      "type": "array<string>",
      "required": false,
      "description": "Claims, causes of action, or legal theories.",
      "section": "document_details",
      "category": "array"
    },
    {
      "name": "key_motions",
      "type": "array<string>",
      "required": false,
      "description": "Key pending or decided motions.",
      "section": "document_details",
      "category": "array"
    },
    {
      "name": "discovery_status",
      "type": "string",
      "required": false,
      "description": "Discovery phase or status.",
      "section": "risk_and_compliance",
      "category": "operational"
    },
    {
      "name": "hearing_dates",
      "type": "array<string>",
