      "category": "array",
      "item_schema": [
        {
          "name": "line_number",
          "type": "string",
          "description": "BOM line number."
        },
        {
          "name": "part_number",
          "type": "string",
          "description": "Component part number."
        },
        {
          "name": "description",
          "type": "string",
          "description": "Component description."
        },
        {
          "name": "revision",
          "type": "string",
          "description": "Component revision."
        },
        {
          "name": "quantity",
          "type": "number",
          "description": "Component quantity."
        },
        {
          "name": "unit",
          "type": "string",
          "description": "Unit of measure."
        }
      ]
    },
    {
      "name": "approved_by",
      "type": "string",
      "required": false,
      "description": "Approver name or function.",
      "section": "document_details",
      "category": "descriptive"
