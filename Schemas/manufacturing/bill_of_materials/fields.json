      "section": "document_details",
      "category": "descriptive"
    },
    {
      "name": "bom_revision",
      "type": "string",
      "required": true,
      "description": "BOM revision level.",
      "section": "document_details",
      "category": "descriptive"
    },
    {
      "name": "parent_part_number",
      "type": "string",
      "required": true,
      "description": "Parent assembly or finished good part number.",
      "section": "property_or_asset",
      "category": "financial"
    },
    {
      "name": "parent_part_description",
      "type": "string",
      "required": false,
      "description": "Parent part description.",
      "section": "financials",
      "category": "financial"
