{
  "document_type": "issue_management_record",
  "vertical": "fs",
  "family": "regulatory_exams_audit",
  "schema_version": "fs_issue_management_record_v1",
  "source_prompt": "prompt_v1.txt",
  "output_contract": {
    "fields_object": "extracted_fields",
    "confidence_object": "confidence",
    "metadata_object": "extraction_metadata"
  },
  "fields": [
    {
      "name": "issue_id",
      "type": "string",
      "required": true,
      "description": "Internal issue, MRA, MRIA, or audit finding identifier.",
      "section": "document_details",
      "category": "descriptive"
    },
    {
      "name": "source_type",
      "type": "string",
      "required": false,
      "description": "Regulatory exam, internal audit, compliance testing, self-identified, or other.",
      "section": "document_details",
      "category": "descriptive"
    },
    {
      "name": "source_name",
      "type": "string",
      "required": false,
      "description": "Regulator, audit group, testing program, or source.",
      "section": "parties",
      "category": "identity"
    },
    {
      "name": "issue_title",
      "type": "string",
      "required": true,
      "description": "Short issue title.",
      "section": "document_details",
      "category": "descriptive"
    },
    {
      "name": "issue_description",
      "type": "string",
      "required": false,
      "description": "Detailed issue or finding description.",
      "section": "document_details",
      "category": "operational"
    },
    {
      "name": "risk_domain",
      "type": "string",
      "required": false,
      "description": "Compliance, credit, operational, model, cyber, liquidity, or other domain.",
      "section": "risk_and_compliance",
      "category": "descriptive"
    },
    {
      "name": "severity",
      "type": "string",
      "required": false,
      "description": "Critical, high, medium, low, MRA, MRIA, or other severity.",
      "section": "document_details",
      "category": "descriptive"
    },
    {
      "name": "status",
      "type": "string",
      "required": true,
      "description": "Open, in progress, pending validation, closed, overdue, or other.",
      "section": "risk_and_compliance",
      "category": "operational"
    },
    {
      "name": "owner_name",
      "type": "string",
      "required": false,
      "description": "Accountable issue owner.",
      "section": "parties",
      "category": "identity"
    },
    {
      "name": "business_unit",
      "type": "string",
      "required": false,
      "description": "Business unit responsible for remediation.",
      "section": "document_details",
      "category": "descriptive"
    },
    {
      "name": "opened_date",
      "type": "date",
      "required": false,
      "description": "Date issue was opened.",
      "section": "dates_and_terms",
      "category": "temporal"
    },
    {
      "name": "target_completion_date",
      "type": "date",
      "required": false,
      "description": "Committed remediation target date.",
      "section": "dates_and_terms",
      "category": "temporal"
    },
    {
      "name": "actual_completion_date",
      "type": "date",
      "required": false,
      "description": "Actual completion date if closed.",
      "section": "dates_and_terms",
      "category": "temporal"
    },
    {
      "name": "corrective_action_plan",
      "type": "string",
      "required": false,
      "description": "Summary of remediation plan.",
      "section": "document_details",
      "category": "descriptive"
    },
    {
      "name": "milestones",
      "type": "array<string>",
      "required": false,
      "description": "Key milestones or deliverables.",
      "section": "document_details",
      "category": "array"
    },
    {
      "name": "evidence_required",
      "type": "array<string>",
      "required": false,
      "description": "Evidence expected for closure.",
      "section": "document_details",
      "category": "array"
    },
    {
      "name": "validation_owner",
      "type": "string",
      "required": false,
      "description": "Independent validation owner or function.",
      "section": "parties",
      "category": "identity"
    },
    {
      "name": "validation_status",
      "type": "string",
      "required": false,
      "description": "Not started, in progress, passed, failed, or other.",
      "section": "risk_and_compliance",
      "category": "operational"
    },
    {
      "name": "regulatory_commitment",
      "type": "boolean",
      "required": false,
      "description": "Whether issue is tied to a regulatory commitment.",
      "section": "risk_and_compliance",
      "category": "regulatory"
    },
    {
      "name": "days_overdue",
      "type": "integer",
      "required": false,
      "description": "Days overdue if stated.",
      "section": "dates_and_terms",
      "category": "temporal"
    }
  ],
  "sections": [
    {
      "id": "dates_and_terms",
      "title": "Dates And Terms",
      "description": "Dates And Terms fields extracted from the document.",
      "fields": [
        "actual_completion_date",
        "days_overdue",
        "opened_date",
        "target_completion_date"
      ]
    },
    {
      "id": "document_details",
      "title": "Document Details",
      "description": "Document Details fields extracted from the document.",
      "fields": [
        "business_unit",
        "corrective_action_plan",
        "evidence_required",
        "issue_description",
        "issue_id",
        "issue_title",
        "milestones",
        "severity",
        "source_type"
      ]
    },
    {
      "id": "parties",
      "title": "Parties",
      "description": "Parties fields extracted from the document.",
      "fields": [
        "owner_name",
        "source_name",
        "validation_owner"
      ]
    },
    {
      "id": "risk_and_compliance",
      "title": "Risk And Compliance",
      "description": "Risk And Compliance fields extracted from the document.",
      "fields": [
        "regulatory_commitment",
        "risk_domain",
        "status",
        "validation_status"
      ]
    }
  ],
  "completeness_checklist": [
    {
      "id": "required_fields_present",
      "description": "All required fields are present or explicitly null with low confidence when absent.",
      "fields": [
        "issue_id",
        "issue_title",
        "status"
      ]
    },
    {
      "id": "section_coverage_reviewed",
      "description": "Each declared section was reviewed for extractable evidence.",
      "sections": [
        "dates_and_terms",
        "document_details",
        "parties",
        "risk_and_compliance"
      ]
    },
    {
      "id": "nested_lists_normalized",
      "description": "Object array fields use their item_schema for consistent nested extraction.",
      "fields": []
    }
  ]
}
